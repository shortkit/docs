{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "shortkit",
  "description": "Drop-in short-form video feeds for your app. TikTok-quality video experience without the infrastructure complexity.",
  "colors": {
    "primary": "#FF6600",
    "light": "#fff8f5",
    "dark": "#121216"
  },
  "background": {
    "color": {
      "light": "#ffffff",
      "dark": "#0f0f12"
    }
  },
  "fonts": {
    "heading": {
      "family": "Public Sans",
      "weight": 600
    },
    "body": {
      "family": "Public Sans",
      "weight": 400
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "icon": "book-open",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "quickstart",
              "core-concepts"
            ]
          },
          {
            "group": "Upload Content",
            "pages": [
              "guides/upload/content-pipeline",
              "guides/upload/transcoding"
            ]
          },
          {
            "group": "Display a Feed",
            "pages": [
              "guides/feed/feed-configuration",
              "guides/feed/ranking",
              "guides/feed/cdn-delivery",
              "guides/feed/deep-linking"
            ]
          },
          {
            "group": "Playback Features",
            "pages": [
              "guides/playback/captions",
              "guides/playback/storyboard-timelines"
            ]
          },
          {
            "group": "Track Engagement",
            "pages": [
              "guides/engagement/engagement-signals",
              "guides/engagement/analytics",
              "guides/engagement/data-export"
            ]
          },
          {
            "group": "Monetize",
            "pages": [
              "guides/monetize/ad-integration",
              "guides/monetize/ad-configuration",
              "guides/monetize/experiments"
            ]
          },
          {
            "group": "Secure & Integrate",
            "pages": [
              "guides/security/identity-management",
              "guides/security/playback-security",
              "guides/security/authentication"
            ]
          },
          {
            "group": "Platforms & SDKs",
            "pages": [
              "sdk/installation",
              "sdk/configuration",
              "sdk/reference"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "square-terminal",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api/introduction",
              "api/authentication",
              "api/errors"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api/content",
              "api/feed",
              "api/analytics",
              "api/configuration"
            ]
          }
        ]
      },
      {
        "tab": "Portal",
        "icon": "gauge",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "portal/overview"
            ]
          },
          {
            "group": "Content",
            "pages": [
              "portal/content-management"
            ]
          },
          {
            "group": "Feed",
            "pages": [
              "portal/feed-configuration",
              "portal/ab-testing"
            ]
          },
          {
            "group": "Analytics",
            "pages": [
              "portal/analytics"
            ]
          },
          {
            "group": "Monetization",
            "pages": [
              "portal/ad-management"
            ]
          },
          {
            "group": "Settings",
            "pages": [
              "portal/settings"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "icon": "clock-rotate-left",
        "groups": [
          {
            "group": "",
            "pages": [
              "changelog"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://shortkit.dev"
  },
  "navbar": {
    "links": [
      {
        "label": "Home",
        "href": "https://shortkit.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Contact Us",
      "href": "https://calendly.com/michael-shortkit/20-min-meeting"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/shortkit",
      "github": "https://github.com/shortkit"
    }
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "one-dark-pro"
      }
    }
  }
}

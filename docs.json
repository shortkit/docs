{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "shortkit",
  "description": "Drop-in short-form video feeds for your app. TikTok-quality video experience without the infrastructure complexity.",
  "colors": {
    "primary": "#FF6600",
    "light": "#fff8f5",
    "dark": "#121216"
  },
  "background": {
    "color": {
      "light": "#ffffff",
      "dark": "#0f0f12"
    }
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "favicon": "/favicon.svg",
  "api": {
    "mdx": {
      "server": "https://api.shortkit.dev",
      "auth": {
        "method": "bearer"
      }
    },
    "playground": {
      "display": "simple"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "icon": "book-open",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "sdk/installation",
              "quickstart"
            ]
          },
          {
            "group": "Content",
            "pages": [
              "guides/content-types",
              "guides/upload-pipeline"
            ]
          },
          {
            "group": "Display",
            "pages": [
              "sdk/feed",
              "sdk/player-and-widget",
              "sdk/configuration"
            ]
          },
          {
            "group": "Build Your Experience",
            "pages": [
              "sdk/player",
              "sdk/overlays",
              "engagement-signals"
            ]
          },
          {
            "group": "Users & Data",
            "pages": [
              "sdk/identity",
              "sdk/analytics"
            ]
          },
          {
            "group": "Roadmap",
            "pages": [
              "coming-soon"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "square-terminal",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api/overview",
              "api/authentication",
              "api/errors"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              {
                "group": "Content",
                "expanded": true,
                "pages": [
                  "api/content/object",
                  "api/content/upload",
                  "api/content/import",
                  "api/content/list",
                  "api/content/get",
                  "api/content/count",
                  "api/content/search",
                  "api/content/update",
                  "api/content/delete"
                ]
              },
              {
                "group": "Surveys",
                "expanded": true,
                "pages": [
                  "api/surveys/object",
                  "api/surveys/create",
                  "api/surveys/list",
                  "api/surveys/get",
                  "api/surveys/update",
                  "api/surveys/delete",
                  "api/surveys/submit-response"
                ]
              },
              {
                "group": "Analytics & Events",
                "expanded": true,
                "pages": [
                  "api/analytics/event-object",
                  "api/analytics/list-events",
                  "api/analytics/metrics",
                  "api/analytics/get-metric",
                  "api/analytics/get-timeseries"
                ]
              },
              {
                "group": "Ad Configuration",
                "expanded": true,
                "pages": [
                  "api/ad-config/object",
                  "api/ad-config/get",
                  "api/ad-config/update"
                ]
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://shortkit.dev"
  },
  "navbar": {
    "links": [
      {
        "label": "Home",
        "href": "https://shortkit.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Contact Us",
      "href": "https://calendly.com/michael-shortkit/20-min-meeting"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {},
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "catppuccin-latte",
        "dark": "tokyo-night"
      }
    }
  }
}

{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "shortkit",
  "description": "Drop-in short-form video feeds for your app. TikTok-quality video experience without the infrastructure complexity.",
  "colors": {
    "primary": "#FF6600",
    "light": "#fff8f5",
    "dark": "#121216"
  },
  "background": {
    "color": {
      "light": "#ffffff",
      "dark": "#0f0f12"
    }
  },
  "fonts": {
    "heading": {
      "family": "Public Sans",
      "weight": 600
    },
    "body": {
      "family": "Public Sans",
      "weight": 400
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "quickstart",
              "core-concepts"
            ]
          },
          {
            "group": "SDK",
            "pages": [
              "sdk/installation",
              "sdk/configuration",
              "sdk/feed",
              "sdk/player",
              "sdk/overlays",
              "sdk/ads",
              "sdk/analytics",
              "sdk/identity"
            ]
          },
          {
            "group": "Developer Guides",
            "pages": [
              "guides/custom-overlays",
              "guides/content-types",
              "guides/captions",
              "guides/upload-pipeline",
              "guides/feed-customization",
              "guides/analytics",
              "guides/server-side-integration"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "square-terminal",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api/introduction",
              "api/authentication",
              "api/errors"
            ]
          },
          {
            "group": "Content",
            "pages": [
              "api/content",
              "api/uploads",
              "api/feed"
            ]
          },
          {
            "group": "Engagement",
            "pages": [
              "api/events",
              "api/analytics",
              "api/views"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "api/ad-config",
              "api/surveys",
              "api/embeds"
            ]
          },
          {
            "group": "Organization",
            "pages": [
              "api/organization"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "icon": "list-check",
        "groups": [
          {
            "group": "Changelog",
            "pages": [
              "changelog"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://shortkit.dev"
  },
  "navbar": {
    "links": [
      {
        "label": "Home",
        "href": "https://shortkit.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Contact Us",
      "href": "https://calendly.com/michael-shortkit/20-min-meeting"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/shortkit",
      "github": "https://github.com/shortkit"
    }
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "vitesse-light",
        "dark": "vitesse-dark"
      }
    }
  }
}
